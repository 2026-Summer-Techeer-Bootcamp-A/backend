# Local dev convenience
# With this set, `docker compose up -d` brings up the FULL local stack
# (app + db + redis + observability). On the GCP VM, DELETE this line so only
# docker-compose.yml is used (db/redis are external Cloud SQL / Memorystore).
COMPOSE_FILE=docker-compose.yml;docker-compose.dev.yml

# App
APP_IMAGE=career-backend:local
APP_PORT=8000
LOG_LEVEL=info
# Production: the DuckDNS domain pointing to the GCP VM (Traefik issues TLS for it).
DOMAIN_NAME=2026-techeer-a.duckdns.org
ACME_EMAIL=admin@example.com

# CORS: frontend origins allowed to call this API from the browser.
# JSON array. Defaults in config.py already include localhost + the Vercel prod URL;
# override here to add/replace origins without touching code.
CORS_ORIGINS=["http://localhost:3000","https://frontend-tan-chi-25.vercel.app"]

# Database (local=dev compose db / production=Cloud SQL private IP)
# POSTGRES_HOST는 docker-compose.yml의 pgbouncer 서비스가 실제 DB(Cloud SQL 또는
# 로컬 db 컨테이너)에 붙을 때 쓰는 값이다. 로컬 dev compose(docker-compose.dev.yml)는
# pgbouncer 없이 app이 db에 직접 붙으므로 DATABASE_URL은 그대로 둔다. 프로덕션은
# pgbouncer를 거치도록 DATABASE_URL의 host를 pgbouncer로 바꿔야 한다(자세한 이유는
# tech-breakthrough/performance/perf-build-journal/13-count-distinct-and-map-query-fix.md).
POSTGRES_HOST=db
POSTGRES_DB=appdb_load
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://appuser:change-me@db:5432/appdb_load

# Redis (local=dev compose redis / production=Memorystore private IP)
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Observability exporters (postgres-exporter/redis-exporter DSN — separate from
# DATABASE_URL/REDIS_URL because postgres_exporter needs a plain postgresql://
# scheme, not +psycopg, and redis_exporter's REDIS_ADDR doesn't take a /<db>
# suffix). production=Cloud SQL/Memorystore private IP.
POSTGRES_EXPORTER_DSN=postgresql://appuser:change-me@db:5432/appdb_load?sslmode=disable
REDIS_EXPORTER_ADDR=redis://redis:6379
SEARCH_CACHE_TTL_SECONDS=10800
SEARCH_CACHE_SOCKET_TIMEOUT_SECONDS=0.5

# Observability
GF_SECURITY_ADMIN_PASSWORD=change-me
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=career-backend

# External API keys
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25.0

# Resume parsing
RESUME_PARSE_MAX_BYTES=10485760
RESUME_CONFIRM_SESSION_TTL_SECONDS=3600

# CI/CD notifications: set these as GitHub Actions secrets, not in .env.
# Discord is live; Slack is a TODO (fill in scripts/notify.py notify_slack).
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
